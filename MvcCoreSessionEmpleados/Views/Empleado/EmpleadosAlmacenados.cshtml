@{
    List<Empleado> empleados = Context.Session.GetObject<List<Empleado>>("EMPLEADOS");
}
@section style{
    <style>
        table{
            width:70%;
            margin:auto;
            text-align:center
        }
        h4{
            text-align:center
        }
        p{
            text-align:center
        }
    </style>
}

<h1>Empleados Almacenados</h1>
<hr />
<p><a asp-controller="Empleado" asp-action="SessionEmpleados" class="btn btn-outline-dark">Volver a empleados</a></p>
<hr />
@if(empleados != null){
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id Empleado</th>
                <th>Apellido</th>
                <th>Oficio</th>
                <th>Salario</th>
                <th>Numero Departamento</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in empleados) {
                <tr>
                    <td>@item.EmpNo</td>
                    <td>@item.Apellido</td>
                    <td>@item.Oficio</td>
                    <td>@item.Salario</td>
                    <td> @item.DeptNo</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <h4>No existen empleados en Session</h4>
}